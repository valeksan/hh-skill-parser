LOGLEVEL=info

# Network tuning for HH requests
HH_CLIENT_CONTACT=
HH_SEND_USER_AGENT=0
HH_BROWSER_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
HTTPS_PROXY=
HTTP_PROXY=

# Request pacing
# HH_ENV_FILE can point to another env file if needed.
HH_ENV_FILE=.env
